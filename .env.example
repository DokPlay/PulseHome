# PulseHome Docker Compose example.
# Copy this file to .env on your server:
#   cp .env.example .env
#
# Then edit .env and replace the values after "=".
# Do not commit .env.

# 1) Database used by PulseHome Analyzer.
# Replace with the database name Docker should create, for example pulsehome_prod.
PULSEHOME_POSTGRES_DB=pulsehome

# Replace with the database username Docker should create, for example pulsehome_app.
PULSEHOME_POSTGRES_USER=pulsehome_app

# Replace with a strong random database password.
PULSEHOME_POSTGRES_PASSWORD=replace-with-strong-db-password

# Keep 127.0.0.1 so PostgreSQL is available only from this server.
PULSEHOME_POSTGRES_BIND_ADDRESS=127.0.0.1

# Host port for local/admin PostgreSQL access on the server. Change only if busy.
PULSEHOME_POSTGRES_HOST_PORT=15432

# 2) Collector API used by your backend or trusted IoT gateway.
# Replace with the username your backend will use for Basic Auth.
COLLECTOR_BASIC_AUTH_USERNAME=pulsehome_ingest

# Replace with a strong random API password. Never put this into frontend code.
COLLECTOR_BASIC_AUTH_PASSWORD=replace-with-strong-collector-api-password

# Keep 127.0.0.1 when Caddy/Nginx runs on the same server.
COLLECTOR_BIND_ADDRESS=127.0.0.1

# Local Collector port on the server. Reverse proxy forwards to this port.
COLLECTOR_HOST_PORT=8080

# First start: false. After HTTPS reverse proxy works: change to true.
COLLECTOR_REQUIRE_HTTPS=false

# 3) Kafka TLS between PulseHome services.
# Replace before the first docker compose up. If you change it later,
# the existing pulsehome-tls-certs volume still has stores with the old password.
TLS_STORE_PASSWORD=replace-with-strong-tls-store-password

# First smoke test: false. Production after PQC provider verification: true.
KAFKA_SSL_PQC_REQUIRE=false

# Keep Kafka private on the server.
KAFKA_HOST_BIND_ADDRESS=127.0.0.1
KAFKA_HOST_PORT=19092

# 4) Hub Router target used by Analyzer for device actions.
# Demo/local stub:
GRPC_HUB_ROUTER_ADDRESS=static://hub-router-stub:59090
GRPC_HUB_ROUTER_NEGOTIATION_TYPE=plaintext

# Real Hub Router example:
# GRPC_HUB_ROUTER_ADDRESS=static://hub-router.your-domain.com:443
# GRPC_HUB_ROUTER_NEGOTIATION_TYPE=TLS

# Keep the local stub private. It is only for smoke tests.
HUB_ROUTER_STUB_BIND_ADDRESS=127.0.0.1
HUB_ROUTER_STUB_HOST_PORT=59090
