        "logicalType": "timestamp-millis"
      }
    },
    {
      "name": "sensorsState",
      "type": {
        "type": "map",
        "values": "ru.yandex.practicum.kafka.telemetry.event.SensorStateAvro"
      }
    }
  ]
}
