{
  "type": "record",
  "name": "MotionSensorAvro",
  "namespace": "ru.yandex.practicum.kafka.telemetry.event",
  "fields": [
    { "name": "link_quality", "type": "int", "doc": "Link quality in percent.", "default": 0 },
    { "name": "motion", "type": "boolean", "doc": "Motion detected flag.", "default": false },
    { "name": "voltage", "type": "int", "doc": "Battery voltage in millivolts.", "default": 0 }
  ]
}
